# ============================================================================
# API CONFIGURATION
# ============================================================================
ENVIRONMENT=development                    # development, staging, production
API_VERSION=1.0.0
API_TITLE=NeuroCommerce OS API
API_HOST=0.0.0.0                          # Bind address (0.0.0.0 for Docker, 127.0.0.1 for local)
API_PORT=8000                              # API port
API_LOG_LEVEL=info                         # info, debug, warning, error

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================
JWT_SECRET_KEY=change-this-to-a-secure-random-key-min-32-chars-in-production  # IMPORTANT: Change in production!
JWT_ALGORITHM=HS256                        # HS256, RS256
JWT_EXPIRATION_HOURS=24                    # Token expiration in hours

# Token Configuration
TOKEN_TYPE=bearer                          # bearer, jwt

# Password Hashing
BCRYPT_ROUNDS=12                           # Higher = more secure but slower (10-14 recommended)

# ============================================================================
# ROLE-BASED ACCESS CONTROL (RBAC)
# ============================================================================
DEFAULT_USER_ROLE=viewer                   # viewer, editor, admin
DEFAULT_ADMIN_ROLE=admin                   # First registered user role

# ============================================================================
# STORE & SUBSCRIPTION CONFIGURATION
# ============================================================================
DEFAULT_STORE_PLAN=starter                 # starter, pro, growth, enterprise
DEFAULT_SUBSCRIPTION_STATUS=active         # active, paused, cancelled

# ID Prefix Configuration (for multi-tenancy and tracking)
STORE_ID_PREFIX=store_
USER_ID_PREFIX=user_
SESSION_ID_PREFIX=sess_
CUSTOMER_ID_PREFIX=cust_
CART_ID_PREFIX=cart_
EVENT_ID_PREFIX=evt_
ACTION_ID_PREFIX=act_
EXPERIMENT_ID_PREFIX=exp_
CAMPAIGN_ID_PREFIX=camp_
APIKEY_ID_PREFIX=key_

# ============================================================================
# CROSS-ORIGIN RESOURCE SHARING (CORS)
# ============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1,neurocommerce.local

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL Connection String
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://neurocommerce:password@postgres:5432/neurocommerce

# IMPORTANT: For production, use a secure password and connection pooling:
# DATABASE_URL=postgresql://user:secure-password@prod-db.example.com:5432/neurocommerce?sslmode=require

# ============================================================================
# CACHE CONFIGURATION (Redis)
# ============================================================================
REDIS_URL=redis://redis:6379/0
CACHE_DEFAULT_EXPIRE=3600                  # 1 hour in seconds
CACHE_SHORT_EXPIRE=300                     # 5 minutes in seconds
CACHE_LONG_EXPIRE=86400                    # 1 day in seconds

# ============================================================================
# MESSAGE QUEUE CONFIGURATION (Kafka)
# ============================================================================
KAFKA_BROKERS=kafka:9092                   # Comma-separated broker addresses
KAFKA_CONSUMER_GROUP=neurocommerce-group   # Consumer group for processing events

# ============================================================================
# CART & SHOPPING CONFIGURATION
# ============================================================================
DEFAULT_CART_STATUS=active                 # active, abandoned, converted

# ============================================================================
# EXPERIMENT CONFIGURATION
# ============================================================================
DEFAULT_EXPERIMENT_STATUS=draft             # draft, running, paused, complete

# ============================================================================
# CAMPAIGN CONFIGURATION
# ============================================================================
DEFAULT_CAMPAIGN_STATUS=draft               # draft, scheduled, running, paused, complete

# ============================================================================
# API KEY CONFIGURATION
# ============================================================================
DEFAULT_API_KEY_ACTIVE=true                 # New API keys active by default

# ============================================================================
# QUERY & PAGINATION
# ============================================================================
DEFAULT_QUERY_LIMIT=100                     # Default query result limit
MAX_QUERY_LIMIT=1000                        # Maximum allowed query limit
DEFAULT_PAGE_SIZE=50                        # Default pagination page size
MAX_PAGE_SIZE=500                           # Maximum allowed page size

# ============================================================================
# ML & AGENT CONFIGURATION (ML Thresholds)
# ============================================================================
# ML Model Confidence Thresholds (0.0 - 1.0)
PURCHASE_PROBABILITY_THRESHOLD=0.6          # Customer purchase likelihood threshold
ABANDONMENT_PROBABILITY_THRESHOLD=0.7       # Cart abandonment likelihood threshold
CHURN_RISK_THRESHOLD=0.75                   # Customer churn risk threshold

# Discount Configuration
MIN_DISCOUNT=0.0                            # Minimum discount percentage
MAX_DISCOUNT=35.0                           # Maximum discount percentage
DEFAULT_DISCOUNT=10.0                       # Default discount percentage

# Agent Confidence Thresholds
MIN_AGENT_CONFIDENCE=0.5                    # Minimum confidence for agent actions
OPTIMAL_AGENT_CONFIDENCE=0.75               # Target confidence level

# ============================================================================
# SHOPIFY INTEGRATION
# ============================================================================
SHOPIFY_API_KEY=your-shopify-api-key        # Get from Shopify Partner Dashboard
SHOPIFY_API_SECRET=your-shopify-api-secret  # Get from Shopify Partner Dashboard
SHOPIFY_SCOPES=read_orders,read_products,read_customers,read_checkouts,write_discounts
SHOPIFY_API_VERSION=2024-01                 # Shopify API version
SHOPIFY_WEBHOOK_TIMEOUT=30                  # Webhook processing timeout in seconds

# ============================================================================
# PAYMENT PROCESSING (Stripe)
# ============================================================================
STRIPE_API_KEY=sk_live_your-stripe-key      # Production: sk_live_*, Staging: sk_test_*
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ============================================================================
# AI & LLM CONFIGURATION
# ============================================================================
OPENAI_API_KEY=sk-your-openai-api-key       # OpenAI API key for GPT
OPENAI_MODEL=gpt-4                          # gpt-4, gpt-4-turbo, gpt-3.5-turbo
OPENAI_TEMPERATURE=0.7                      # Creativity (0.0-2.0): 0=deterministic, 1=creative
OPENAI_MAX_TOKENS=1000                      # Maximum tokens per request

# ============================================================================
# EMAIL & SMS CONFIGURATION
# ============================================================================
# SendGrid Email Configuration
SENDGRID_API_KEY=SG_your-sendgrid-key       # SendGrid API key
SENDGRID_FROM_EMAIL=noreply@neurocommerce.io # Sender email address

# Twilio SMS Configuration
TWILIO_ACCOUNT_SID=ACyour-account-sid       # Twilio Account SID
TWILIO_AUTH_TOKEN=your-auth-token           # Twilio Auth Token
TWILIO_PHONE_NUMBER=+1234567890             # Twilio phone number for SMS

# ============================================================================
# ANALYTICS & OBSERVABILITY
# ============================================================================
PROMETHEUS_ENABLED=true                     # Enable Prometheus metrics
PROMETHEUS_PORT=9090                        # Prometheus port
OTEL_ENABLED=false                          # Enable OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ============================================================================
# CLICKHOUSE ANALYTICS DATABASE
# ============================================================================
CLICKHOUSE_URL=http://clickhouse:8123/neurocommerce
CLICKHOUSE_BATCH_SIZE=100                   # Batch size for ClickHouse inserts
CLICKHOUSE_BATCH_TIMEOUT=5                  # Batch timeout in seconds

# ============================================================================
# REQUEST & RATE LIMITING
# ============================================================================
REQUEST_TIMEOUT=30                          # Request timeout in seconds
MAX_BATCH_SIZE=1000                         # Maximum batch event size
RATE_LIMIT_ENABLED=true                     # Enable rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100          # Rate limit per minute per user
